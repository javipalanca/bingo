{
  "name": "pixel-bombo",
  "version": "1.0.0",
  "main": "main.js",
  "private": true,
  "description": "Bombo pixelart que saca imágenes de una carpeta",
  "scripts": {
    "start": "electron .",
    "start:web": "python3 -m uvicorn backend.main:app --reload --port 5173",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f bingo-web"
  },
  "devDependencies": {
    "electron": "^30.0.0"
  },
  "dependencies": {
    "gsap": "^3.14.2",
    "matter-js": "^0.20.0",
    "pixi.js": "^8.16.0",
    "split.js": "^1.6.5"
  }
}
